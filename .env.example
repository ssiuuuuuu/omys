# Backend
ENVIRONMENT=development
DATABASE_URL=sqlite:///./omys.db
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
PLACES_PROVIDER=mock
GOOGLE_PLACES_API_KEY=
KAKAO_REST_API_KEY=
TMAP_API_KEY=
VITE_KAKAO_JAVASCRIPT_KEY=
VITE_KAKAO_SHARE_JAVASCRIPT_KEY=
ADMIN_API_KEY=replace-with-a-long-random-secret
MIN_STAY_MINUTES=60
SEARCH_CACHE_SECONDS=180

# Compose PostgreSQL
POSTGRES_DB=omys
POSTGRES_USER=omys
POSTGRES_PASSWORD=change-this-password

# Frontend (leave blank when using the Vite proxy)
VITE_API_BASE_URL=
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000

# Compose host ports (container-to-container ports stay unchanged)
OMYS_API_PORT=8010
OMYS_DB_PORT=5433
