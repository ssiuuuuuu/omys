# Copy this file to .env.kcloud and replace every placeholder.
# Use only letters and numbers in POSTGRES_PASSWORD because it is embedded in a URL.
POSTGRES_DB=omys
POSTGRES_USER=omys
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_ALPHANUMERIC_PASSWORD

# Start with http://PUBLIC_IP. Replace it with https://YOUR_DOMAIN after TLS is configured.
PUBLIC_ORIGIN=http://PUBLIC_IP
APP_PORT=8080

PLACES_PROVIDER=kakao
KAKAO_REST_API_KEY=REPLACE_WITH_KAKAO_REST_API_KEY
TMAP_API_KEY=REPLACE_WITH_TMAP_API_KEY
VITE_KAKAO_JAVASCRIPT_KEY=REPLACE_WITH_KAKAO_JAVASCRIPT_KEY
GOOGLE_PLACES_API_KEY=

ADMIN_API_KEY=REPLACE_WITH_A_LONG_RANDOM_ADMIN_KEY
MIN_STAY_MINUTES=60
SEARCH_CACHE_SECONDS=180
